# ============================================================
# YoudaoNoteLM 环境变量配置
# 复制此文件为 .env 并修改对应的值
# cp .env.example .env
# ============================================================

# ============================================================
# Docker 容器环境变量
# ============================================================

# 镜像配置（默认从 Docker Hub 拉取；本地构建时注释掉即可）
DOCKER_IMAGE=flandern/youdaonote:latest
MARKITDOWN_IMAGE=flandern/markitdown:latest

# 应用端口（服务器部署建议改为 18080 避免冲突）
APP_PORT=8080

# MySQL
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=youdao
MYSQL_PORT=3306

# Redis
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# MinIO 对象存储
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Milvus 向量数据库
MILVUS_PORT=19530
MILVUS_MINIO_ACCESS_KEY=minioadmin
MILVUS_MINIO_SECRET_KEY=minioadmin

# MarkItDown 文档转换
MARKITDOWN_PORT=8085

# ============================================================
# 应用配置变量（覆盖 docker_config.yaml 中的空字段）
# 缺少以下变量会导致启动失败或功能不可用
# ============================================================

# MySQL 连接密码（通常与 MYSQL_ROOT_PASSWORD 一致）
MYSQL_PASSWORD=your_mysql_root_password

# JWT 签名密钥（必填）
JWT_SECRET=your_jwt_secret_key

# 邮箱 SMTP 密码（必填）
EMAIL_PASSWORD=your_email_password

# API Key 加密密钥（必填，必须恰好 32 字节）
ENCRYPTION_KEY=your_32_byte_encryption_key

# MinIO 访问密钥（通常与 MINIO_ROOT_USER/PASSWORD 一致）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_password

# MinIO 公网可达地址（用于 ASR 下载音频文件，格式: 公网IP:端口）
MINIO_PUBLIC_ENDPOINT=your_public_ip:9000

# 博查搜索 API Key（留空则禁用联网搜索）
BOCHA_API_KEY=
