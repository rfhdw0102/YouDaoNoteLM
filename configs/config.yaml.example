# YouDaoNoteLM 配置文件示例
# 复制此文件为 config.yaml 并修改对应的值
# cp config.yaml.example config.yaml

# 服务器配置
app:
  name: "youdao-api"
  version: "1.0.0"
  mode: "debug"  # debug, release, test
  port: 8080

# 数据库配置
database:
  mysql:
    host: "localhost"
    port: 3306
    username: "root"
    password: "your_mysql_password"
    database: "youdao"
    max_idle_conns: 10
    max_open_conns: 100
  redis:
    host: "localhost"
    port: 6379
    password: "your_redis_password"
    db: 15
    pool_size: 10

# JWT 配置
jwt:
  secret: "your-random-jwt-secret-key-here"  # 请修改为随机生成的密钥
  access_token_exp: "15m"     # Access Token 过期时间：15 分钟
  refresh_token_exp: "24h"    # Refresh Token 过期时间：1 天
  issuer: "youdaonotelm"      # Token 签发者

# 日志配置
log:
  level: "debug"  # debug, info, warn, error
  filename: "logs/app.log"
  max_size: 100    # MB
  max_backups: 3   # 保留旧文件的最大个数
  max_age: 28      # 保留旧文件的最大天数
  compress: true   # 是否压缩

# 邮箱配置
email:
  host: "smtp.qq.com"
  port: 587
  username: "your_email@qq.com"
  password: "your_email_password"
  from: "your_email@qq.com"

# Milvus 向量数据库配置
milvus:
  host: "localhost"
  port: 19530

# CORS 配置
cors:
  enabled: true
  allow_origins:
    - "*"
  allow_methods:
    - "GET"
    - "POST"
    - "PUT"
    - "PATCH"
    - "DELETE"
    - "OPTIONS"
  allow_headers:
    - "Authorization"
    - "Content-Type"
    - "Origin"
    - "Accept"
  expose_headers:
    - "Content-Length"
  allow_credentials: true
  max_age: 86400

# 外部服务配置
external:
  markitdown:
    url: "http://localhost:8085"       # MarkItDown 文档转换服务地址
  minio:
    endpoint: "localhost:9000"             # SDK 连接用（容器内/本地可达）
    public_endpoint: ""                    # URL 重写用（外部访问），留空则不重写；生产由 MINIO_PUBLIC_ENDPOINT 覆盖
    access_key: "minioadmin"
    secret_key: "your_minio_password"
    bucket: "youdaonotelm"
  youdao:
    cli_path: "youdaonote"  # CLI 路径，默认在 PATH 中查找，也可指定绝对路径
    converter_script_path: "scripts/youdao/convert_to_markdown.py"  # 转换脚本路径（本地开发用）
    # converter_script_path: "/app/scripts/youdao/convert_to_markdown.py"  # Docker 容器内路径
    cookies_path: ""  # youdaonote cookies 文件路径（可选，用于 .note 格式转换）
  bocha:
    base_url: "https://api.bochaai.com"
    endpoint: "/v1/web-search"
    api_key: "your_bocha_api_key"
    timeout_seconds: 15
    default_count: 5
    summary: true
    cache_ttl_seconds: 300
    max_count: 10
